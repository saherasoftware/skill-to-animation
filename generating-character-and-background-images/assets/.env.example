# Story-to-Animation — API Keys
# Copy this file to your project directory as ".env" and fill in your keys.
# (The scripts auto-create this file on first run if .env is missing.)

# kie.ai API key — https://kie.ai -> Dashboard -> API Keys
REPLICATE_API_TOKEN=your_kie_api_key_here

# imgbb API key — https://api.imgbb.com (free account)
# Used by generate_images.py to host images publicly for the video pipeline.
IMGBB_API_KEY=your_imgbb_api_key_here
